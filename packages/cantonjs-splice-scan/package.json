{
  "name": "cantonjs-splice-scan",
  "version": "0.3.0",
  "description": "Public Scan client for Splice networks, built on cantonjs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental/index.d.ts",
      "import": "./dist/experimental/index.js",
      "default": "./dist/experimental/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node ../../scripts/verify-coverage-exclusions.mjs && vitest run --coverage",
    "clean": "rm -rf dist",
    "generate:types": "SPLICE_TAG=\"$(find ../../vendor/splice -mindepth 1 -maxdepth 1 -type d -exec basename {} \\; | sort -V | tail -n1)\" && npx openapi-typescript \"../../vendor/splice/${SPLICE_TAG}/openapi/scan.yaml\" -o \"./src/generated/scan.types.ts\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "canton",
    "splice",
    "scan",
    "typescript",
    "client"
  ],
  "author": "Charles Dusek",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merged-one/cantonjs.git",
    "directory": "packages/cantonjs-splice-scan"
  },
  "peerDependencies": {
    "cantonjs": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.0.0",
    "cantonjs": "file:../..",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=18"
  }
}
