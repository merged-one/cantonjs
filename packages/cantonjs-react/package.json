{
  "name": "cantonjs-react",
  "version": "0.2.0",
  "description": "React hooks for Canton Network dApps — built on cantonjs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "canton",
    "daml",
    "react",
    "hooks",
    "blockchain",
    "ledger"
  ],
  "author": "Charles Dusek",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merged-one/cantonjs.git",
    "directory": "packages/cantonjs-react"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "cantonjs": "^0.2.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "cantonjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^29.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
